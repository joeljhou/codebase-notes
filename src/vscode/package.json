{
  "name": "codebase-notes-vscode",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "icon": "images/icon.png",
  "version": "0.1.21",
  "publisher": "joeljhou",
  "private": true,
  "license": "MIT",
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/joeljhou/codebase-notes.git",
    "directory": "src/vscode"
  },
  "homepage": "https://github.com/joeljhou/codebase-notes#readme",
  "bugs": {
    "url": "https://github.com/joeljhou/codebase-notes/issues"
  },
  "markdown": "github",
  "qna": "https://github.com/joeljhou/codebase-notes/issues",
  "galleryBanner": {
    "color": "#080B1A",
    "theme": "dark"
  },
  "keywords": [
    "codebase",
    "notes",
    "annotations",
    "documentation",
    "onboarding",
    "architecture",
    "repository",
    "files",
    "folders",
    "team",
    "jetbrains",
    "trae"
  ],
  "engines": {
    "node": ">=22",
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "copy:schema": "node scripts/copy-schema.mjs",
    "compile:test": "npm run copy:schema && tsc -p tsconfig.json",
    "bundle": "npm run copy:schema && node scripts/build.mjs",
    "compile": "npm run compile:test && npm run bundle",
    "typecheck": "npm run copy:schema && tsc -p tsconfig.json --noEmit",
    "verify:spec": "node ../../scripts/verify-config-contracts.mjs",
    "test": "npm run verify:spec && npm run test:unit",
    "test:unit": "npm run compile:test && node --test \"dist/test/**/*.test.js\"",
    "prepare:integration": "node scripts/prepare-integration-workspace.mjs",
    "test:integration": "npm run compile && npm run prepare:integration && vscode-test --label integration",
    "vscode:prepublish": "npm run bundle",
    "package": "vsce package --no-dependencies",
    "publish:marketplace": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "jsonc-parser": "3.3.1",
    "minimatch": "^10.2.5"
  },
  "devDependencies": {
    "@types/node": "22.20.1",
    "@types/vscode": "1.107.0",
    "@vscode/test-cli": "0.0.15",
    "@vscode/test-electron": "3.0.0",
    "@vscode/vsce": "3.9.2",
    "esbuild": "0.28.1",
    "typescript": "7.0.2"
  },
  "contributes": {
    "colors": [
      {
        "id": "codebaseNotes.noteStyle.infoForeground",
        "description": "%color.noteStyle.info.description%",
        "defaults": {
          "dark": "#60A5FA",
          "light": "#2563EB",
          "highContrast": "#75BEFF",
          "highContrastLight": "#1D4ED8"
        }
      },
      {
        "id": "codebaseNotes.noteStyle.successForeground",
        "description": "%color.noteStyle.success.description%",
        "defaults": {
          "dark": "#4ADE80",
          "light": "#15803D",
          "highContrast": "#70E59A",
          "highContrastLight": "#166534"
        }
      },
      {
        "id": "codebaseNotes.noteStyle.warningForeground",
        "description": "%color.noteStyle.warning.description%",
        "defaults": {
          "dark": "#FBBF24",
          "light": "#B45309",
          "highContrast": "#FFD54F",
          "highContrastLight": "#92400E"
        }
      },
      {
        "id": "codebaseNotes.noteStyle.dangerForeground",
        "description": "%color.noteStyle.danger.description%",
        "defaults": {
          "dark": "#F87171",
          "light": "#DC2626",
          "highContrast": "#FF8A8A",
          "highContrastLight": "#B91C1C"
        }
      }
    ],
    "commands": [
      {
        "command": "codebaseNotes.editNote",
        "title": "%command.editNote.title%",
        "category": "%command.category%"
      },
      {
        "command": "codebaseNotes.setNoteStyle",
        "title": "%command.setNoteStyle.title%",
        "category": "%command.category%"
      },
      {
        "command": "codebaseNotes.removeNote",
        "title": "%command.removeNote.title%",
        "category": "%command.category%"
      },
      {
        "command": "codebaseNotes.searchNotes",
        "title": "%command.searchNotes.title%",
        "category": "%command.category%"
      },
      {
        "command": "codebaseNotes.relinkNote",
        "title": "%command.relinkNote.title%",
        "category": "%command.category%"
      },
      {
        "command": "codebaseNotes.relinkPrefix",
        "title": "%command.relinkPrefix.title%",
        "category": "%command.category%"
      },
      {
        "command": "codebaseNotes.refresh",
        "title": "%command.refresh.title%",
        "category": "%command.category%"
      },
      {
        "command": "codebaseNotes.revealInNotes",
        "title": "%command.revealInNotes.title%",
        "category": "%command.category%",
        "icon": "$(note)"
      },
      {
        "command": "codebaseNotes.revealInExplorer",
        "title": "%command.revealInExplorer.title%",
        "category": "%command.category%",
        "icon": "$(files)"
      }
    ],
    "keybindings": [
      {
        "command": "codebaseNotes.editNote",
        "key": "alt+r"
      },
      {
        "command": "codebaseNotes.setNoteStyle",
        "key": "shift+alt+r"
      }
    ],
    "submenus": [
      {
        "id": "codebaseNotes.explorerContext",
        "label": "%submenu.label%",
        "icon": "$(note)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "codebaseNotes.annotatedFiles",
          "name": "%view.annotatedFiles.name%",
          "contextualTitle": "%view.annotatedFiles.contextualTitle%",
          "visibility": "visible"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "submenu": "codebaseNotes.explorerContext",
          "when": "resourceScheme == file",
          "group": "navigation@80"
        }
      ],
      "codebaseNotes.explorerContext": [
        {
          "command": "codebaseNotes.revealInNotes",
          "when": "view != codebaseNotes.annotatedFiles",
          "group": "0_navigation@1"
        },
        {
          "command": "codebaseNotes.revealInExplorer",
          "when": "view == codebaseNotes.annotatedFiles",
          "group": "0_navigation@1"
        },
        {
          "command": "codebaseNotes.editNote",
          "when": "(resourceScheme == file || resourceScheme == codebase-notes) && viewItem != codebaseNotes.config && viewItem != codebaseNotes.unavailable && viewItem != codebaseNotes.missing",
          "group": "1_note@1"
        },
        {
          "command": "codebaseNotes.setNoteStyle",
          "when": "(resourceScheme == file || resourceScheme == codebase-notes) && viewItem != codebaseNotes.config && viewItem != codebaseNotes.unavailable && viewItem != codebaseNotes.missing",
          "group": "1_note@2"
        },
        {
          "command": "codebaseNotes.removeNote",
          "when": "(resourceScheme == file || resourceScheme == codebase-notes) && viewItem != codebaseNotes.config && viewItem != codebaseNotes.unavailable && viewItem != codebaseNotes.missing",
          "group": "2_clear@1"
        }
      ],
      "view/title": [
        {
          "command": "codebaseNotes.searchNotes",
          "when": "view == codebaseNotes.annotatedFiles",
          "group": "navigation@1"
        },
        {
          "command": "codebaseNotes.refresh",
          "when": "view == codebaseNotes.annotatedFiles",
          "group": "navigation@2"
        },
        {
          "command": "codebaseNotes.revealInExplorer",
          "when": "view == codebaseNotes.annotatedFiles",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "submenu": "codebaseNotes.explorerContext",
          "when": "view == codebaseNotes.annotatedFiles && (viewItem == codebaseNotes.root || viewItem == codebaseNotes.rootWithNote || viewItem == codebaseNotes.entry || viewItem == codebaseNotes.entryWithNote)",
          "group": "navigation@1"
        },
        {
          "command": "codebaseNotes.relinkNote",
          "when": "view == codebaseNotes.annotatedFiles && viewItem == codebaseNotes.missing",
          "group": "inline@1"
        }
      ]
    }
  }
}
