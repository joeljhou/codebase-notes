      }
    },
    {
      "id": "path/reject-backslash",
      "input": {
        "key": "src\\App.ts"
      },
      "expected": {
        "valid": false
      }
    },
    {
      "id": "path/reject-config",
      "input": {
        "key": "pkg/.codebase-notes.json"
      },
      "expected": {
        "valid": false
      }
    }
  ]
}
